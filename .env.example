# --- LLM provider selection (3-tier) ---
# LLM_*         -> primary model, used by the composer (final answer)
# CLASSIFIER_*  -> understand_query (light intent extraction)
# EXECUTOR_*    -> execute_db (tool-calling loop)
#
# Providers: anthropic | google_genai
# Examples:  claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5
#            gemini-3.1-pro, gemini-3.1-flash, gemini-3.1-flash-lite-preview
#
# Recommended for lowest latency with decent quality:
#   LLM_*=gemini-3.1-pro   (composer needs quality)
#   CLASSIFIER_*=EXECUTOR_*=gemini-3.1-flash-lite-preview
LLM_PROVIDER=google_genai
LLM_MODEL=gemini-3.1-flash-lite-preview
LLM_TEMPERATURE=0

# Leave blank to reuse LLM_MODEL
CLASSIFIER_PROVIDER=google_genai
CLASSIFIER_MODEL=gemini-3.1-flash-lite-preview

EXECUTOR_PROVIDER=google_genai
EXECUTOR_MODEL=gemini-3.1-flash-lite-preview

# --- Embeddings (for the policy vector store) ---
# Providers: huggingface (local, offline) | google_genai | openai
EMBEDDINGS_PROVIDER=huggingface
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Hybrid retrieval ---
# top-k final chunks; semantic_weight is dense share (bm25 gets 1 - that)
TOP_K=8
SEMANTIC_WEIGHT=0.7
USE_RERANKING=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Provider API keys (set whichever you use) ---
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# --- Database ---
# SQLAlchemy URL for the payment-transaction DB.
# Dev (local Postgres seeded from schema.sql):
#   postgresql+psycopg://user:pass@localhost:5432/payments
# Prod (legacy xpress schema): supply the real URL.
DATABASE_URL= postgresql+psycopg://postgres:root@localhost:5432/payments
DB_SCHEMA=public

# --- Vector store ---
VECTORSTORE_DIR=./vectorstore/policies
VECTORSTORE_COLLECTION=policies
POLICIES_DIR=./policies

# --- Checkpointer (LangGraph persistence) ---
# memory | postgres
CHECKPOINTER=memory
CHECKPOINTER_POSTGRES_URL=
