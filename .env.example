# --- LLM provider selection ---
# Pick ONE primary provider. Examples:
#   anthropic   -> claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5
#   google_genai -> gemini-3.1-pro, gemini-3.1-flash, gemini-3.1-flash-lite-preview
LLM_PROVIDER=google_genai
LLM_MODEL=gemini-3.1-flash-lite-preview
LLM_TEMPERATURE=0

# Optional: use a different (usually cheaper) model for the lightweight
# classification / intent-extraction step. Leave blank to reuse LLM_MODEL.
# Good pairing: primary=gemini-3.1-pro, classifier=gemini-3.1-flash-lite-preview
CLASSIFIER_PROVIDER=
CLASSIFIER_MODEL=

# --- Embeddings (for the policy vector store) ---
# Supported providers: google_genai, openai
# gemini: gemini-embedding-001 (latest), text-embedding-004
# openai: text-embedding-3-small (1536 dim), text-embedding-3-large
EMBEDDINGS_PROVIDER=google_genai
EMBEDDINGS_MODEL=gemini-embedding-001

# --- Provider API keys (set whichever you use) ---
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# --- Database ---
# SQLAlchemy URL for the payment-transaction DB.
# Dev (local Postgres seeded from schema.sql):
#   postgresql+psycopg://user:pass@localhost:5432/payments
# Prod (legacy xpress schema): supply the real URL.
DATABASE_URL= postgresql+psycopg://postgres:root@localhost:5432/payments
DB_SCHEMA=public

# --- Vector store ---
VECTORSTORE_DIR=./vectorstore/policies
VECTORSTORE_COLLECTION=policies
POLICIES_DIR=./policies

# --- Checkpointer (LangGraph persistence) ---
# memory | postgres
CHECKPOINTER=memory
CHECKPOINTER_POSTGRES_URL=
